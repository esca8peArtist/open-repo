#!/bin/bash
set -e
                                                                                                                
WORKSPACE="$HOME/dev/SuperClaude_Framework"                                        
PROMPT_FILE="$WORKSPACE/.claude/orchestrator-prompt.md"
LOG_FILE="$WORKSPACE/orchestrator.log"
MAX_TURNS=80
PAUSE_BETWEEN_SESSIONS=300

cd "$WORKSPACE"
[ -f "$HOME/.claude_env" ] && source "$HOME/.claude_env"

echo "[$(date)] Orchestrator starting." | tee -a "$LOG_FILE"
[ -n "$DISCORD_WEBHOOK_URL" ] && curl -s -H "Content-Type: application/json" -d "{\"content\":\"[Claude] Orchestrator   
starting on Pi\"}" "$DISCORD_WEBHOOK_URL" > /dev/null 2>&1 || true

while true; do
  echo "[$(date)] Starting Claude session..." | tee -a "$LOG_FILE"
  claude --dangerously-skip-permissions --max-turns "$MAX_TURNS" -p "$(cat "$PROMPT_FILE")" 2>&1 | tee -a "$LOG_FILE"
  echo "[$(date)] Session ended. Pausing ${PAUSE_BETWEEN_SESSIONS}s..." | tee -a "$LOG_FILE"
  [ -n "$DISCORD_WEBHOOK_URL" ] && curl -s -H "Content-Type: application/json" -d "{\"content\":\"[Claude] Session
ended. Next in $((PAUSE_BETWEEN_SESSIONS/60))min.\"}" "$DISCORD_WEBHOOK_URL" > /dev/null 2>&1 || true
  sleep "$PAUSE_BETWEEN_SESSIONS"
done
