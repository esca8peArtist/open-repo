# OpenRide Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Database
POSTGRES_USER=openride
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=openride

# Application
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
DATABASE_URL=postgresql+asyncpg://openride:CHANGE_ME@db:5432/openride
REDIS_URL=redis://:openride@redis:6379/0
REDIS_PASSWORD=openride

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMS - Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# OSRM routing
OSRM_URL=http://osrm:5000

# Optional
CORS_ORIGINS=https://admin.yourdomain.com,https://api.yourdomain.com
LOG_LEVEL=info
MAX_MATCHING_RADIUS_KM=8
DRIVER_LOCATION_TTL_S=30
