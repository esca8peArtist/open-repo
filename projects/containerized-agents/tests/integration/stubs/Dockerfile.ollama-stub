# Dockerfile.ollama-stub — slim Python image running the Ollama stub server
# Built by docker-compose.test.yml for integration tests.

FROM python:3.12-slim

WORKDIR /app

# Install only what the stub needs
RUN pip install --no-cache-dir fastapi uvicorn[standard]

COPY ollama_stub.py .

EXPOSE 11434

CMD ["uvicorn", "ollama_stub:app", "--host", "0.0.0.0", "--port", "11434"]
