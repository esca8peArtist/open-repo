# config.env — Open WebUI environment variables
# Containerized AI Agents — v1.0
#
# This file is sourced by docker-compose.yml via env_file for the open-webui service.
# Secrets (WEBUI_SECRET_KEY, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB) are
# supplied from the top-level .env file and interpolated at compose start time.
#
# Reference: https://docs.openwebui.com/getting-started/env-configuration

# ---------------------------------------------------------------------------
# Inference Backend
# ---------------------------------------------------------------------------
# Ollama is the local LLM inference engine, reachable via the Docker network.
OLLAMA_BASE_URL=http://ollama:11434

# ---------------------------------------------------------------------------
# Branding & URL
# ---------------------------------------------------------------------------
WEBUI_NAME=AgentCore
WEBUI_URL=http://agent.local

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Disable self-registration — admin creates all user accounts via the admin panel.
ENABLE_SIGNUP=false
ENABLE_LOGIN_FORM=true

# ---------------------------------------------------------------------------
# Locale
# ---------------------------------------------------------------------------
DEFAULT_LOCALE=en

# ---------------------------------------------------------------------------
# RAG / Web Search
# ---------------------------------------------------------------------------
# Disabled: web search is handled by AgentCore tool dispatch, not Open WebUI.
ENABLE_RAG_WEB_SEARCH=false

# ---------------------------------------------------------------------------
# Image Generation
# ---------------------------------------------------------------------------
# Not included in this product SKU.
ENABLE_IMAGE_GENERATION=false

# ---------------------------------------------------------------------------
# Audio — Speech-to-Text (STT)
# ---------------------------------------------------------------------------
# faster-whisper is exposed through AgentCore's OpenAI-compatible /v1 proxy.
AUDIO_STT_ENGINE=openai
AUDIO_STT_OPENAI_API_BASE_URL=http://agentcore:8080/v1

# ---------------------------------------------------------------------------
# Audio — Text-to-Speech (TTS)
# ---------------------------------------------------------------------------
# Kokoro-82M TTS is exposed through AgentCore's OpenAI-compatible /v1 proxy.
AUDIO_TTS_ENGINE=openai
AUDIO_TTS_OPENAI_API_BASE_URL=http://agentcore:8080/v1
# Kokoro default voice: af_heart (American Female, natural tone)
AUDIO_TTS_VOICE=af_heart

# ---------------------------------------------------------------------------
# Community & Social Features
# ---------------------------------------------------------------------------
# All sharing and community features are disabled for self-hosted offline deployment.
ENABLE_COMMUNITY_SHARING=false
ENABLE_MESSAGE_RATING=false

# ---------------------------------------------------------------------------
# Security — injected from .env at compose start time
# ---------------------------------------------------------------------------
# WEBUI_SECRET_KEY is a randomly generated secret; must be set in .env.
WEBUI_SECRET_KEY=${WEBUI_SECRET_KEY}

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string; credentials are injected from .env.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
