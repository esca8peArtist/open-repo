# =============================================================================
# Dockerfile.agentcore
# AgentCore — Containerized AI Agent Orchestration API
#
# Python 3.12-slim base. Runs the AgentCore FastAPI service on port 8080.
#
# Multi-arch build notes:
#   python:3.12-slim  — official multi-arch image; amd64 and arm64 are both
#                        available from Docker Hub.  No change required.
#   faster-whisper    — depends on CTranslate2 C++ wheels.  Pre-built wheels
#                        exist for amd64 and arm64 (aarch64) on PyPI as of
#                        CTranslate2 v4.x / faster-whisper v1.x, so install
#                        is attempted on all platforms but made non-fatal so
#                        ARM64 Jetson builds succeed even if a wheel is absent.
#   ctranslate2       — ARM64 wheels available on PyPI; install succeeds on
#                        Jetson JetPack 6 (aarch64-linux-gnu).  Non-fatal for
#                        future compatibility with RISC-V or other arches.
#   chromadb-client   — pure-Python; works on all platforms.
#   asyncpg           — C extension; arm64 wheels available.
#   cryptography      — C extension; arm64 wheels available via manylinux.
# =============================================================================

# Injected automatically by `docker buildx build --platform`
ARG TARGETPLATFORM
ARG BUILDPLATFORM

ARG PYTHON_VERSION=3.12
FROM python:${PYTHON_VERSION}-slim AS base

# Build args (injected by build_compose_bundle.sh)
ARG BUNDLE_VERSION=dev
ARG PROFILE=base
ARG GIT_SHA=unknown
ARG BUILD_DATE=unknown
ARG TARGETPLATFORM
ARG BUILDPLATFORM

# OCI labels
LABEL org.opencontainers.image.title="AgentCore"
LABEL org.opencontainers.image.description="Containerized AI Agent Orchestration API"
LABEL org.opencontainers.image.version="${BUNDLE_VERSION}"
LABEL org.opencontainers.image.revision="${GIT_SHA}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.vendor="AgentCore"
LABEL agentcore.profile="${PROFILE}"

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        jq \
        tpm2-tools \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Install uv (fast Python package manager)
# ---------------------------------------------------------------------------
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# ---------------------------------------------------------------------------
# Application user (non-root)
# ---------------------------------------------------------------------------
RUN groupadd --gid 1001 agentcore \
    && useradd --uid 1001 --gid agentcore --no-create-home --shell /usr/sbin/nologin agentcore

# ---------------------------------------------------------------------------
# Working directory
# ---------------------------------------------------------------------------
WORKDIR /app

# ---------------------------------------------------------------------------
# Python dependencies (cached layer)
# Install before copying source so layer cache survives source changes.
# ---------------------------------------------------------------------------
COPY pyproject.toml uv.lock* ./

RUN uv sync --frozen --no-dev 2>/dev/null \
    || uv pip install \
        fastapi>=0.115 \
        uvicorn[standard]>=0.32 \
        httpx>=0.27 \
        pydantic>=2.9 \
        pydantic-settings>=2.6 \
        asyncpg>=0.30 \
        redis[asyncio]>=5.2 \
        chromadb-client>=0.5 \
        openai-agents>=0.1 \
        python-multipart>=0.0.12 \
        python-jose[cryptography]>=3.3 \
        passlib[bcrypt]>=1.7 \
        structlog>=24.4 \
        tenacity>=9.0

# ---------------------------------------------------------------------------
# Optional heavy dependencies — voice / STT
# ARM64 (Jetson) note: CTranslate2 arm64 wheels are published on PyPI.
# faster-whisper bundles CTranslate2; install is attempted on all platforms
# but made non-fatal so builds succeed on platforms without pre-built wheels.
# If install fails, voice STT features are disabled at runtime.
# ---------------------------------------------------------------------------
ARG TARGETPLATFORM
RUN pip install ctranslate2 \
    || echo "WARNING: ctranslate2 not available on ${TARGETPLATFORM}, voice features may be limited"

RUN pip install faster-whisper \
    || echo "WARNING: faster-whisper not available on ${TARGETPLATFORM}, voice STT disabled"

# ---------------------------------------------------------------------------
# Application source
# ---------------------------------------------------------------------------
COPY src/agentcore/ ./agentcore/

# Data directory (mounted as named volume at runtime)
RUN mkdir -p /app/data && chown agentcore:agentcore /app/data

# ---------------------------------------------------------------------------
# Runtime configuration
# ---------------------------------------------------------------------------
USER agentcore

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PORT=8080
ENV HOST=0.0.0.0

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=5 \
    CMD curl -f http://localhost:8080/health || exit 1

# ---------------------------------------------------------------------------
# Entrypoint
# ---------------------------------------------------------------------------
CMD ["python", "-m", "uvicorn", "agentcore.server:app", \
     "--host", "0.0.0.0", \
     "--port", "8080", \
     "--workers", "1", \
     "--loop", "asyncio"]
