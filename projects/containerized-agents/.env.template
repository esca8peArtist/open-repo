# =============================================================================
# .env.template — AgentCore Environment Variables
# Copy this file to .env and fill in required values.
#
#   cp .env.template .env
#   vim .env
#
# Lines beginning with # are comments.
# Variables marked REQUIRED must be set before `docker compose up`.
# Variables with defaults can be left as-is for local dev / single-agent use.
# =============================================================================


# ---------------------------------------------------------------------------
# Build / version metadata
# Set by the build pipeline; override here if deploying a specific version.
# ---------------------------------------------------------------------------

# Semver bundle version. Must match what images were built with.
# REQUIRED
BUNDLE_VERSION=1.0.0

# Agent profile. One of: personal | customer-support | sales | developer | bi | enterprise | base
# REQUIRED
PROFILE=base


# ---------------------------------------------------------------------------
# Security secrets  — CHANGE ALL OF THESE BEFORE GOING LIVE
# ---------------------------------------------------------------------------

# Secret key for Open WebUI session encryption (any random string ≥ 32 chars)
# REQUIRED — must be set to a strong random value; do not leave as placeholder.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBUI_SECRET_KEY=

# Internal API key used by Open WebUI → AgentCore
# REQUIRED — must be set to a strong random value.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTCORE_API_KEY=

# Internal secret for AgentCore JWT / session signing
# REQUIRED — must be set to a strong random value; server will refuse to start without it.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTCORE_SECRET=


# ---------------------------------------------------------------------------
# PostgreSQL database
# ---------------------------------------------------------------------------

POSTGRES_USER=agentcore
# REQUIRED — set a strong, unique password before first start.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
# AgentCore will refuse to start if this is left blank or set to a known-weak value.
POSTGRES_PASSWORD=
POSTGRES_DB=agentcore
# Full DSN consumed by AgentCore (REQUIRED — must not use placeholder passwords).
# Update <password> to match POSTGRES_PASSWORD above.
POSTGRES_URL=postgresql+asyncpg://agentcore:<password>@postgres:5432/agentcore
# Host/port the DB port is bound to on the host (use 127.0.0.1 for local only)
POSTGRES_HOST=127.0.0.1
POSTGRES_EXPOSE_PORT=5432


# ---------------------------------------------------------------------------
# Redis message queue
# ---------------------------------------------------------------------------

# REQUIRED — set a strong password for Redis auth.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
# AgentCore will refuse to start if this is left blank or set to a known-weak value.
REDIS_PASSWORD=
# Full DSN consumed by AgentCore (REQUIRED — must not use placeholder passwords).
# Update <password> to match REDIS_PASSWORD above.
REDIS_URL=redis://:<password>@redis:6379/0
# Maximum memory Redis may use (e.g. 512mb, 1gb)
REDIS_MAXMEMORY=512mb
REDIS_HOST=127.0.0.1
REDIS_EXPOSE_PORT=6379


# ---------------------------------------------------------------------------
# ChromaDB vector database
# ---------------------------------------------------------------------------

# Leave blank to disable token auth (fine for local-only deployments)
CHROMA_TOKEN=
CHROMA_AUTH_HEADER=X-Chroma-Token
CHROMA_AUTH_PROVIDER=
CHROMADB_HOST=127.0.0.1
CHROMADB_EXPOSE_PORT=8000


# ---------------------------------------------------------------------------
# Ollama inference engine
# ---------------------------------------------------------------------------

# Maximum number of models loaded in memory simultaneously
OLLAMA_MAX_LOADED_MODELS=2
# Maximum parallel inference requests
OLLAMA_NUM_PARALLEL=1
# How long to keep a loaded model in memory after last request
OLLAMA_KEEP_ALIVE=5m
# Bind host for Ollama port (127.0.0.1 = localhost only, NEVER use 0.0.0.0 per CLAUDE.md)
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434


# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------

WEBUI_NAME=AgentCore
# Public URL (used for QR code and links; set to your mDNS name or IP)
WEBUI_URL=http://agent.local
# Bind host for WebUI port (ALWAYS 127.0.0.1 for local, or explicit Tailscale IP for remote)
WEBUI_HOST=127.0.0.1
WEBUI_PORT=3000
# Disable self-signup (wizard creates the admin account)
WEBUI_ENABLE_SIGNUP=false
WEBUI_DEFAULT_ROLE=user
# Enable web search via Ollama's built-in (requires internet)
WEBUI_ENABLE_WEB_SEARCH=false


# ---------------------------------------------------------------------------
# AgentCore API
# ---------------------------------------------------------------------------

# Bind host for AgentCore API (ALWAYS 127.0.0.1 for local, or explicit Tailscale IP for remote)
AGENTCORE_HOST=127.0.0.1
AGENTCORE_PORT=8080
# Internal base URL used by channel services (telegram, twilio) to call AgentCore APIs.
# In a single-container deployment this is http://localhost:8080.
# In Docker Compose, use the service name: http://agentcore:8080
AGENTCORE_BASE_URL=http://localhost:8080
# Environment: development | production
ENVIRONMENT=production


# ---------------------------------------------------------------------------
# First-boot wizard
# ---------------------------------------------------------------------------

# Bind host for Setup Wizard (ALWAYS 127.0.0.1 for local, or explicit Tailscale IP for remote)
WIZARD_HOST=127.0.0.1
WIZARD_PORT=8888


# ---------------------------------------------------------------------------
# Hardware binding (populated automatically by wizard — do not edit manually)
# ---------------------------------------------------------------------------

# SHA-256 hardware fingerprint derived from TPM EK + CPU serial + board UUID + MAC
HARDWARE_FINGERPRINT=
# License key bound to this hardware fingerprint
LICENSE_KEY=


# ---------------------------------------------------------------------------
# Communication channels (all optional — configured during wizard)
# ---------------------------------------------------------------------------

# --- Telegram Bot (free, no per-message cost; requires internet when messaging) ---
# Create a bot via @BotFather, paste the token here
TELEGRAM_BOT_TOKEN=

# --- Twilio (SMS + WhatsApp; customer's own account; requires internet) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# ---------------------------------------------------------------------------
# Optional integrations (configured during wizard)
# ---------------------------------------------------------------------------

# --- Google Calendar (Profile 1: Personal Productivity) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Web search ---
# Tavily API key for high-quality structured web search.
# Leave empty to fall back to DuckDuckGo (no key required).
# Obtain a key at https://tavily.com/
TAVILY_API_KEY=

# --- GitHub ---
# Personal access token (classic) or fine-grained token with repo scope.
# Required for the search_code, get_file, create_issue, and list_pull_requests tools.
GITHUB_TOKEN=

# --- CRM (SQLite) ---
# Path to the local SQLite CRM database file.
# Created automatically if it does not exist.
CRM_DB_PATH=/data/crm.db

# --- Database query tool ---
# Additional database connections for the query_database MCP tool.
# These are separate from the main POSTGRES_URL used by AgentCore itself.
DB_SQLITE_PATH=
DB_POSTGRES_URL=
DB_MYSQL_URL=

# --- Email (IMAP/SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USE_TLS=true
IMAP_HOST=localhost
IMAP_PORT=993
IMAP_USE_SSL=true
EMAIL_USER=
EMAIL_PASSWORD=
# From: address used when sending mail. Defaults to EMAIL_USER if left empty.
EMAIL_FROM=

# --- Filesystem tool ---
# Colon-separated list of absolute path prefixes the filesystem MCP tool may read.
# Defaults to /data:/workspace if left empty.
FILESYSTEM_ALLOWED_PATHS=

# --- CalDAV calendar ---
# Works with Google Calendar, Nextcloud, Apple Calendar, and any CalDAV server.
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=

# --- PDF report output ---
# Directory where generated PDF reports are saved.
REPORT_OUTPUT_DIR=/data/reports

# --- Scheduler database ---
# PostgreSQL DSN for the scheduled_tasks table.
# Falls back to DB_POSTGRES_URL, then a local SQLite file (/data/scheduler.db).
SCHEDULER_DB_URL=

# --- Update verification ---
# Ed25519 public key (hex-encoded raw 32-byte key) used to verify the
# cryptographic signature on update manifests fetched from the update server.
# Injected by the build pipeline from secrets manager — do NOT hardcode in source.
#
# To generate a key pair for self-hosted update signing:
#   openssl genpkey -algorithm ed25519 -out update_private.pem
#   openssl pkey -in update_private.pem -pubout -out update_public.pem
#   # Extract the raw 32-byte public key as hex:
#   openssl pkey -in update_public.pem -pubin -outform DER \
#     | dd bs=1 skip=12 2>/dev/null | xxd -p -c 256
#
# Alternatively, use the Ed25519 key generation tooling in security/hardware_binding/.
UPDATE_PUBLIC_KEY_HEX=

# --- Update server (we host this; change only if self-hosting updates) ---
UPDATE_SERVER_URL=https://updates.agentcore.io/manifest.json
