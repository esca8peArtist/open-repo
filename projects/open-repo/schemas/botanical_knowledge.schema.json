{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Botanical Knowledge and Species Data Schema",
  "description": "Extended schema for botanical species covering edibility, toxicity, medicinal properties, and cross-domain linking. Extends seed_preservation schema with safety-critical botanical classification fields.",
  "type": "object",
  "required": [
    "species_id",
    "common_name",
    "latin_binomial",
    "family",
    "edibility_classification"
  ],
  "properties": {
    "species_id": {
      "type": "string",
      "pattern": "^bot_[a-z0-9_]+$",
      "description": "Unique identifier for botanical species, prefixed with 'bot_'"
    },
    "common_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "Common name(s) for the plant, may include regional variants"
    },
    "common_name_variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Alternative common names by region or culture"
    },
    "latin_binomial": {
      "type": "string",
      "pattern": "^[A-Z][a-z]+ [a-z]+$",
      "description": "Scientific binomial name (Genus species)"
    },
    "family": {
      "type": "string",
      "description": "Plant family classification"
    },
    "usda_plants_symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$",
      "description": "USDA PLANTS database code symbol"
    },
    "usda_hardiness_zones": {
      "type": "object",
      "properties": {
        "minimum_zone": {
          "type": "integer",
          "minimum": 1,
          "maximum": 13
        },
        "maximum_zone": {
          "type": "integer",
          "minimum": 1,
          "maximum": 13
        }
      }
    },
    "edibility_classification": {
      "type": "string",
      "enum": [
        "edible_safe",
        "edible_with_preparation",
        "toxic",
        "unknown",
        "partially_edible"
      ],
      "description": "Safety-critical: whether plant is safe to eat - MUST BE CONSERVATIVE"
    },
    "edible_parts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "part_name": {
            "type": "string",
            "enum": [
              "fruit",
              "seed",
              "leaf",
              "root",
              "tuber",
              "bulb",
              "stem",
              "flower",
              "bark"
            ]
          },
          "edibility": {
            "type": "string",
            "enum": [
              "edible",
              "inedible",
              "edible_raw",
              "edible_cooked_only",
              "edible_with_preparation"
            ]
          },
          "preparation_required": {
            "type": "string",
            "description": "How to prepare this part (e.g., 'boil 20 minutes', 'dry before eating')"
          },
          "toxins_in_this_part": {
            "type": "string",
            "description": "Any toxins present even after preparation"
          }
        }
      },
      "description": "Which plant parts are edible and how to prepare them"
    },
    "toxicity_notes": {
      "type": "object",
      "description": "Safety-critical toxicity information",
      "properties": {
        "toxic_classification": {
          "type": "string",
          "enum": [
            "non_toxic",
            "mildly_toxic",
            "moderately_toxic",
            "highly_toxic",
            "unknown"
          ]
        },
        "toxic_parts": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Which parts contain toxins (e.g., 'seeds', 'roots', 'all parts')"
          }
        },
        "toxic_compounds": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "compound_name": {
                "type": "string",
                "description": "e.g., 'solanine', 'cyanogenic glycosides', 'oxalates'"
              },
              "concentration": {
                "type": "string",
                "description": "e.g., 'high', 'moderate', 'trace amounts'"
              },
              "symptoms_of_poisoning": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "What happens if consumed (e.g., 'nausea, vomiting, abdominal pain')"
              },
              "treatment": {
                "type": "string",
                "description": "First aid/treatment (e.g., 'activated charcoal, seek medical help')"
              }
            }
          }
        },
        "minimum_toxic_dose": {
          "type": "string",
          "description": "Approximate amount that causes toxicity if known"
        },
        "source_citation": {
          "type": "object",
          "properties": {
            "source_type": {
              "type": "string"
            },
            "reference": {
              "type": "string"
            }
          },
          "description": "Scientific source for toxicity data"
        }
      }
    },
    "lookalike_hazards": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "lookalike_species_name",
          "danger_level",
          "distinguishing_features"
        ],
        "properties": {
          "lookalike_species_name": {
            "type": "string",
            "description": "Common and Latin names of species this could be confused with"
          },
          "danger_level": {
            "type": "string",
            "enum": [
              "low",
              "moderate",
              "high",
              "critical"
            ],
            "description": "How dangerous if confused"
          },
          "reason_for_confusion": {
            "type": "string",
            "description": "What characteristics make them similar"
          },
          "distinguishing_features": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "description": "Key differences for safe identification (must be observable by non-expert)"
          },
          "toxicity_of_lookalike": {
            "type": "string",
            "description": "Is the lookalike toxic? How bad?"
          }
        }
      },
      "description": "Plants this species might be confused with and how to tell them apart - CRITICAL FOR SAFETY"
    },
    "medicinal_uses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "use_name": {
            "type": "string",
            "description": "What condition is treated (e.g., 'fever reduction', 'digestive aid')"
          },
          "evidence_level": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C"
            ],
            "description": "A=clinical trial published in peer review, B=traditional use with systematic documentation, C=anecdotal only - MUST BE CONSERVATIVE"
          },
          "preparation_method": {
            "type": "string",
            "description": "How to prepare (e.g., 'tea from dried leaves', 'tincture in alcohol')"
          },
          "dosage": {
            "type": "string",
            "description": "How much to take (e.g., '1-2 cups per day')"
          },
          "contraindications": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "When not to use this plant"
          },
          "side_effects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_citation": {
            "type": "object",
            "properties": {
              "source_type": {
                "type": "string",
                "enum": [
                  "clinical_trial",
                  "traditional_medicine_text",
                  "ethnobotanical_documentation",
                  "anecdotal"
                ]
              },
              "reference": {
                "type": "string"
              },
              "year": {
                "type": "integer"
              }
            }
          }
        },
        "required": [
          "use_name",
          "evidence_level",
          "source_citation"
        ]
      },
      "description": "Documented medicinal uses - MUST CITE PRIMARY SOURCE"
    },
    "nutrient_content": {
      "type": "object",
      "description": "Nutritional profile of edible parts",
      "properties": {
        "macronutrients": {
          "type": "object",
          "properties": {
            "protein_grams_per_100g": {
              "type": "number"
            },
            "carbohydrate_grams_per_100g": {
              "type": "number"
            },
            "fat_grams_per_100g": {
              "type": "number"
            },
            "fiber_grams_per_100g": {
              "type": "number"
            }
          }
        },
        "micronutrients": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "nutrient": {
                "type": "string",
                "description": "e.g., 'Vitamin C', 'Iron', 'Calcium'"
              },
              "amount_per_100g": {
                "type": "string",
                "description": "e.g., '45 mg', '2.1 mg'"
              },
              "daily_value_percent": {
                "type": "number",
                "description": "% of daily recommended value"
              }
            }
          }
        }
      }
    },
    "culinary_uses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cuisine_type": {
            "type": "string",
            "description": "e.g., 'Traditional European', 'Asian', 'Indigenous American'"
          },
          "uses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "How used in cooking (e.g., 'salads', 'soups', 'tea')"
          },
          "flavor_profile": {
            "type": "string",
            "description": "Taste and texture"
          }
        }
      }
    },
    "ecological_characteristics": {
      "type": "object",
      "properties": {
        "native_range": {
          "type": "string",
          "description": "Geographic region where native"
        },
        "growth_habit": {
          "type": "string",
          "enum": [
            "annual",
            "biennial",
            "perennial",
            "herbaceous",
            "shrub",
            "tree",
            "vine"
          ]
        },
        "preferred_habitat": {
          "type": "string",
          "description": "e.g., 'moist shaded woodlands', 'open prairies', 'rocky slopes'"
        },
        "invasiveness": {
          "type": "string",
          "description": "Whether plant spreads aggressively; can be invasive in some regions"
        }
      }
    },
    "propagation_methods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "seed",
          "rhizome",
          "bulb",
          "corm",
          "tuber",
          "cutting",
          "layering",
          "division"
        ]
      }
    },
    "illustration": {
      "type": "object",
      "description": "Image for ZIM illustration variants",
      "properties": {
        "wikimedia_commons_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to CC-licensed image on Wikimedia Commons"
        },
        "image_license": {
          "type": "string",
          "enum": [
            "CC_BY",
            "CC_BY_SA",
            "CC0",
            "PD"
          ]
        },
        "attribution_required": {
          "type": "string",
          "description": "Attribution text if required by license"
        },
        "image_fetched_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "related_botanical_articles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "related_species_id": {
            "type": "string",
            "description": "ZIM internal link to related species article"
          },
          "relationship_type": {
            "type": "string",
            "enum": [
              "botanical_relative",
              "lookalike",
              "companion_plant",
              "toxic_relative",
              "similar_culinary_use"
            ]
          }
        }
      }
    },
    "related_medical_articles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "medical_article_id": {
            "type": "string",
            "description": "ZIM internal link to medical article using this herb"
          },
          "medical_use": {
            "type": "string",
            "description": "What condition it treats"
          },
          "evidence_level": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C"
            ]
          }
        }
      },
      "description": "Cross-links to medical reference articles mentioning this plant as treatment"
    },
    "historical_uses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "time_period": {
            "type": "string",
            "description": "e.g., 'Medieval Europe', 'Traditional Chinese Medicine', 'Indigenous North America'"
          },
          "uses": {
            "type": "string",
            "description": "How plant was used historically"
          }
        }
      }
    },
    "source_citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_type"
        ],
        "properties": {
          "source_type": {
            "type": "string",
            "enum": [
              "USDA_PLANTS",
              "scientific_paper",
              "ethnobotanical_text",
              "field_guide",
              "traditional_medicine_compendium"
            ]
          },
          "source_document": {
            "type": "string"
          },
          "publication_year": {
            "type": "integer"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "accessed_date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "content_review_status": {
      "type": "object",
      "properties": {
        "toxicity_reviewed_by": {
          "type": "string",
          "description": "Name/credential of person who reviewed toxicity classifications"
        },
        "medicinal_claims_reviewed": {
          "type": "boolean",
          "description": "Whether medicinal evidence levels have been fact-checked"
        },
        "lookalike_hazards_reviewed": {
          "type": "boolean",
          "description": "Whether distinguishing features are accurate"
        },
        "last_content_review_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    }
  }
}
